# Copy this file to .env for local development:  cp .env.example .env
# Used by `make run` (local `go run .`). For `make up`, docker-compose injects
# its own values, so this file is not consulted there.

# HTTP server
SERVER_PORT=8080

# Postgres — matches the docker-compose `db` service, which publishes
# 5432 on the host as 5433. Run `make up` first so the database is reachable.
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=expense_splitter
DB_SSLMODE=disable

# Keycloak (auth). Running locally with `make run`, the server is on the host and
# reaches the dockerized Keycloak published on :8081, so JWKS and issuer use the
# same address. Under `make up`, docker-compose overrides these with the
# internal `keycloak:8080` JWKS URL. KEYCLOAK_ISSUERS is comma-separated.
KEYCLOAK_JWKS_URL=http://localhost:8081/realms/expense-splitter/protocol/openid-connect/certs
KEYCLOAK_ISSUERS=http://localhost:8081/realms/expense-splitter
KEYCLOAK_AUDIENCE=expense-splitter-api
