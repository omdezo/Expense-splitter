# Copy this file to .env for local development:  cp .env.example .env
# Used by `make run` (local `go run .`). For `make up`, docker-compose injects
# its own values, so this file is not consulted there.

# HTTP server
SERVER_PORT=8080

# Postgres — matches the docker-compose `db` service, which publishes
# 5432 on the host as 5433. Run `make up` first so the database is reachable.
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=expense_splitter
DB_SSLMODE=disable
