# Production secrets — copy to .env and fill in, then: make up-prod
#
#   cp .env.prod.example .env
#
# .env is gitignored. Every variable here is REQUIRED: docker-compose.prod.yml
# uses the ${VAR:?} form, so the stack refuses to start if any is missing rather
# than silently falling back to a dev default.
#
# Generate strong values, e.g.:  openssl rand -base64 32

# ── Application database ──────────────────────────────────────────────
DB_USER=expense_splitter
DB_PASSWORD=CHANGE_ME
DB_NAME=expense_splitter

# ── Keycloak's own database (separate from the app DB, on purpose) ─────
KC_DB_USER=keycloak
KC_DB_PASSWORD=CHANGE_ME

# ── Keycloak admin console ────────────────────────────────────────────
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=CHANGE_ME

# The browser-facing Keycloak URL, with scheme and no trailing slash.
# Tokens are minted with this as their issuer and the API validates against it,
# so a mismatch here means every request 401s.
KEYCLOAK_PUBLIC_URL=https://auth.example.com

# ── Object storage for proof images (MinIO) ───────────────────────────
STORAGE_ACCESS_KEY=CHANGE_ME
STORAGE_SECRET_KEY=CHANGE_ME

# ── Application ───────────────────────────────────────────────────────
# The account `make seed` promotes to global admin.
GLOBAL_ADMIN_EMAIL=admin@your-domain.com
